{
  "manifest_version": 3,
  "name": "HindSite",
  "version": "1.0.0",
  "description": "Automatically saves important webpages based on time and scroll behavior",
  "permissions": [
    "storage","tabs"
  ],
  "icons": {
    "16": "src/assets/icons/ext-icon-16.png",
    "32": "src/assets/icons/ext-icon-32.png",
    "48": "src/assets/icons/ext-icon-48.png",
    "128": "src/assets/icons/ext-icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/index.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "View Saved Pages",
    "default_icon": {
      "16": "src/assets/icons/action-icon-16.png",
      "32": "src/assets/icons/action-icon-32.png",
      "48": "src/assets/icons/action-icon-48.png",
      "128": "src/assets/icons/action-icon-128.png"
    }
  }
}